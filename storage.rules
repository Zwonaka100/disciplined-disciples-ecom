rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'zmabege@gmail.com' ||
        request.auth.token.email == 'nomaqhizazolile@gmail.com'
      );
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*') &&
             request.resource.size < 5 * 1024 * 1024; // Max 5MB
    }

    // Product images - TEMPORARILY open for testing, then change back to isAdmin()
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // Blog images - admins can upload, everyone can view
    match /blog/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidImage();
    }

    // Community images - authenticated users can upload their own
    match /community/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId && isValidImage();
    }

    // User profile images
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId && isValidImage();
    }

    // Default deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
